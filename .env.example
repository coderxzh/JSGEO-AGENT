# OpenAI dispatcher
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_BASE_URL=https://xint.cc
OPENAI_REASONING_EFFORT=medium

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEEP_THINKING=true
DEEPSEEK_REASONING_EFFORT=high

# Doubao / Volcengine Ark
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-lite-260428
DOUBAO_REASONING_EFFORT=high
DOUBAO_ASSISTANT_MODEL=

# Knowledge extraction model
# Optional: ark | deepseek | openai. If empty, the app picks the first configured provider.
GEO_EXTRACTION_PROVIDER=ark
GEO_EXTRACTION_MODEL=doubao-seed-2-0-lite-260428
# Ark/Doubao Chat Completions models may reject json_object. Keep this empty unless your model supports it.
GEO_EXTRACTION_RESPONSE_FORMAT=

# Task models. UI uses Auto; the app chooses model/network mode by task.
GEO_GENERATION_MODEL=
GEO_REFLECTION_MODEL=

# Ark embedding for local sqlite-vec knowledge retrieval.
ARK_EMBEDDING_MODEL=
ARK_EMBEDDING_DIMENSIONS=1024
ARK_EMBEDDING_CONCURRENCY=2
