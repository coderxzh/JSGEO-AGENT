{
  "name": "geo-agent-studio-ui-shell",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "src/main/index.cjs",
  "scripts": {
    "dev": "node scripts/check-dev-port.cjs && concurrently -k \"vite --port=3000 --host=127.0.0.1 --strictPort\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.cjs",
    "lint": "npm run typecheck",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','server.js']) fs.rmSync(p,{recursive:true,force:true});\"",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@volcengine/ark-runtime": "^1.0.9",
    "adm-zip": "^0.5.17",
    "ai": "^6.0.191",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "pdf-parse": "^1.1.1",
    "radix-ui": "^1.4.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.8.2",
    "sqlite-vec": "^0.1.9",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.4",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.jingshan.geoagentstudio",
    "productName": "GEO-Agent Studio",
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/shared/**/*",
      ".env.example",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
